{
  "name": "gmai_pulse_gwam_ca_ret_daily",
  "tags": {
    "project": "gmai-pulse",
    "domain": "gwam_retirement"
  },
  "timeout_seconds": 7200,
  "max_concurrent_runs": 1,
  "parameters": [
    {"name": "target_catalog", "default": "__SET_ME__"},
    {"name": "mode", "default": "incremental"},
    {"name": "start_date", "default": "2026-02-01"},
    {"name": "repo_root", "default": ""}
  ],
  "job_clusters": [
    {
      "job_cluster_key": "gmai_pulse_cluster",
      "new_cluster": {
        "spark_version": "16.4.x-scala2.12",
        "node_type_id": "__SET_ME_NODE_TYPE__",
        "num_workers": 1,
        "data_security_mode": "SINGLE_USER",
        "spark_env_vars": {"OMP_NUM_THREADS": "1"},
        "custom_tags": {"project": "gmai-pulse"}
      }
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 6 * * ?",
    "timezone_id": "America/Toronto",
    "pause_status": "PAUSED"
  },
  "email_notifications": {
    "on_failure": ["__ALERT_EMAIL__"]
  },
  "tasks": [
    {
      "task_key": "freshness_guard",
      "job_cluster_key": "gmai_pulse_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/__SET_ME__/anomoly-detection/databricks/src/00_freshness_guard",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 900000
    },
    {
      "task_key": "bronze",
      "depends_on": [{"task_key": "freshness_guard"}],
      "job_cluster_key": "gmai_pulse_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/__SET_ME__/anomoly-detection/databricks/src/01_bronze_ingest",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 900000
    },
    {
      "task_key": "silver",
      "depends_on": [{"task_key": "bronze"}],
      "job_cluster_key": "gmai_pulse_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/__SET_ME__/anomoly-detection/databricks/src/02_silver_conform",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 900000
    },
    {
      "task_key": "gold",
      "depends_on": [{"task_key": "silver"}],
      "job_cluster_key": "gmai_pulse_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/__SET_ME__/anomoly-detection/databricks/src/03_gold_kpis",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 900000
    },
    {
      "task_key": "detect",
      "depends_on": [{"task_key": "gold"}],
      "job_cluster_key": "gmai_pulse_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/__SET_ME__/anomoly-detection/databricks/src/04_detect",
        "source": "WORKSPACE"
      },
      "libraries": [{"pypi": {"package": "pyod==2.0.5"}}],
      "max_retries": 1,
      "min_retry_interval_millis": 900000
    }
  ]
}
